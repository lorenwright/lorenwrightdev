---
---

<div class="rounded-xl overflow-hidden border border-ctp-surface1 shadow-2xl shadow-ctp-crust/60 font-mono text-sm leading-relaxed">

  <!-- Title bar -->
  <div class="relative flex items-center px-4 py-3 bg-ctp-mantle border-b border-ctp-surface0">
    <div class="flex gap-1.5 z-10">
      <div class="w-3 h-3 rounded-full bg-ctp-red"></div>
      <div class="w-3 h-3 rounded-full bg-ctp-yellow"></div>
      <div class="w-3 h-3 rounded-full bg-ctp-green"></div>
    </div>
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
      <span class="text-ctp-subtext0 text-xs">~/portfolio</span>
    </div>
  </div>

  <!-- Body -->
  <div class="bg-ctp-base px-5 py-4 space-y-0.5">

    <!-- whoami -->
    <div class="terminal-line" style="animation-delay: 0.1s">
      <span class="text-ctp-green">loren</span><span class="text-ctp-overlay1">@</span><span class="text-ctp-blue">localhost</span><span class="text-ctp-overlay1"> ~ $</span>
      <span class="text-ctp-text"> whoami</span>
    </div>
    <div class="terminal-line text-ctp-subtext1 pl-1" style="animation-delay: 0.3s">
      Loren Wright — senior software engineer
    </div>
    <div class="terminal-line h-3" style="animation-delay: 0.4s"></div>

    <!-- cat stack.txt -->
    <div class="terminal-line" style="animation-delay: 0.6s">
      <span class="text-ctp-green">loren</span><span class="text-ctp-overlay1">@</span><span class="text-ctp-blue">localhost</span><span class="text-ctp-overlay1"> ~ $</span>
      <span class="text-ctp-text"> cat stack.txt</span>
    </div>
    <div class="terminal-line pl-1" style="animation-delay: 0.8s">
      <span class="text-ctp-overlay1 mr-3">languages</span><span class="text-ctp-subtext1">typescript · php · sass</span>
    </div>
    <div class="terminal-line pl-1" style="animation-delay: 0.95s">
      <span class="text-ctp-overlay1 mr-3">frontend &nbsp;</span><span class="text-ctp-subtext1">react · vue · tailwind</span>
    </div>
    <div class="terminal-line pl-1" style="animation-delay: 1.1s">
      <span class="text-ctp-overlay1 mr-3">backend &nbsp;&nbsp;</span><span class="text-ctp-subtext1">node.js · postgres · prisma · graphql</span>
    </div>
    <div class="terminal-line h-3" style="animation-delay: 1.2s"></div>

    <!-- git log -->
    <div class="terminal-line" style="animation-delay: 1.4s">
      <span class="text-ctp-green">loren</span><span class="text-ctp-overlay1">@</span><span class="text-ctp-blue">localhost</span><span class="text-ctp-overlay1"> ~ $</span>
      <span class="text-ctp-text"> git log --oneline -3</span>
    </div>
    <div class="terminal-line pl-1" style="animation-delay: 1.6s">
      <span class="text-ctp-yellow">a3f1e2b</span>
      <span class="text-ctp-green"> feat:</span>
      <span class="text-ctp-subtext1"> zero-downtime migration across 6m+ rows</span>
    </div>
    <div class="terminal-line pl-1" style="animation-delay: 1.75s">
      <span class="text-ctp-yellow">c9d8b7a</span>
      <span class="text-ctp-red"> fix:</span>
      <span class="text-ctp-subtext1"> prevent double-charge on concurrent requests</span>
    </div>
    <div class="terminal-line pl-1" style="animation-delay: 1.9s">
      <span class="text-ctp-yellow">e5f4c3d</span>
      <span class="text-ctp-green"> feat:</span>
      <span class="text-ctp-subtext1"> agentic intake flow, cut admin time by 80%</span>
    </div>
    <div class="terminal-line h-3" style="animation-delay: 2.0s"></div>

    <!-- Prompt + blinking cursor -->
    <div class="terminal-line flex items-center" style="animation-delay: 2.1s">
      <span class="text-ctp-green">loren</span><span class="text-ctp-overlay1">@</span><span class="text-ctp-blue">localhost</span><span class="text-ctp-overlay1"> ~ $</span>
      <span class="ml-2 inline-block w-2 h-[1.1em] bg-ctp-text animate-blink align-middle"></span>
    </div>

  </div>
</div>
